{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "services/database.ts",
    "services/auth.ts",
    "services/storage.ts",
    "middleware/authMiddleware.ts",
    "routes/auth.ts",
    "routes/items.ts",
    "routes/journals.ts",
    "routes/stickers.ts",
    "routes/halls.ts"
  ]
}
