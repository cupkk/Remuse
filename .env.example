# ============================================
# Re-Museum environment variables
# Copy this file to `.env` and fill in real values.
# Never commit real secrets.
# ============================================

# Required: your real Gemini-compatible API key.
GEMINI_API_KEY=your_real_api_key_here

# Optional: Gemini-compatible upstream endpoint.
# Official Gemini example:
# 12AI Gemini endpoint. Docs list https://new.12ai.org as main and https://hk.12ai.org as backup.
GEMINI_BASE_URL=https://new.12ai.org
GEMINI_FALLBACK_BASE_URLS=https://hk.12ai.org,https://cdn.12ai.org

# Optional: DashScope / Alibaba Bailian embedding service.
# Used by Memory RAG stage 2 for vector indexing and retrieval.
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
# DASHSCOPE_EMBEDDING_DIMENSION=1024

# Server port and bind host.
PORT=3000
HOST=127.0.0.1

# Required in production. Use a long random secret.
JWT_SECRET=replace_with_a_long_random_secret

# Optional persistent storage locations.
# APP_ROOT=/home/ecs-user/Re-Museum
# DB_PATH=./data/remuse.db
# UPLOADS_DIR=./uploads

# Upload hardening.
MAX_UPLOAD_BYTES=6291456
MAX_IMAGE_DIMENSION=4096
MAX_INPUT_PIXELS=16777216
