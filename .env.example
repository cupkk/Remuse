# ============================================
# Re-Museum environment variables
# Copy this file to `.env` and fill in real values.
# Never commit real secrets.
# ============================================

# Required: Gemini-compatible image upstream key.
GEMINI_API_KEY=your_real_api_key_here

# Required: StepFun text-model key.
STEPFUN_API_KEY=your_stepfun_api_key_here
STEPFUN_BASE_URL=https://api.stepfun.com/v1
# STEPFUN_TEXT_MODEL=step-3.5-flash
# STEPFUN_TEXT_MODEL_CANDIDATES=step-3.5-flash
# STEPFUN_GUIDE_TEXT_MODEL_CANDIDATES=step-3.5-flash
# STEPFUN_MEMORY_MODEL=step-3.5-flash
# STEPFUN_MEMORY_MODEL_CANDIDATES=step-3.5-flash
# STEPFUN_VISION_MODEL=step-1v-8k
# STEPFUN_VISION_MODEL_CANDIDATES=step-1v-8k
# STEPFUN_TIMEOUT_MS=90000
# STEPFUN_SCAN_TIMEOUT_MS=30000
# STEPFUN_GUIDE_TIMEOUT_MS=35000
# STEPFUN_SHORT_TEXT_TIMEOUT_MS=12000

# Optional: Gemini-compatible upstream endpoint.
# Default to the original 12ai proxy.
GEMINI_BASE_URL=https://cdn.12ai.org
GEMINI_FALLBACK_BASE_URLS=https://hk.12ai.org
ALLOW_THIRD_PARTY_GEMINI_PROXY=true
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# GEMINI_IMAGE_MODEL_CANDIDATES=gemini-3-pro-image-preview,gemini-3.1-flash-image-preview,gemini-2.5-flash-image-preview
# GEMINI_GUIDE_IMAGE_MODEL=gemini-3.1-flash-image-preview
# GEMINI_GUIDE_IMAGE_MODEL_CANDIDATES=gemini-3.1-flash-image-preview,gemini-3-pro-image-preview,gemini-2.5-flash-image-preview
# ENABLE_GUIDE_AI_IMAGE=true
# GEMINI_GUIDE_IMAGE_TIMEOUT_MS=110000
# ENABLE_COVER_AI_FALLBACK=false
# GEMINI_STICKER_IMAGE_TIMEOUT_MS=90000
# GEMINI_COVER_IMAGE_TIMEOUT_MS=90000
# GEMINI_PERLER_IMAGE_TIMEOUT_MS=90000
# GEMINI_EMOJI_IMAGE_TIMEOUT_MS=140000

# Optional: DashScope / Alibaba Bailian embedding service.
# Used by Memory RAG stage 2 for vector indexing and retrieval.
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
# DASHSCOPE_EMBEDDING_DIMENSION=1024

# Server port and bind host.
PORT=3000
HOST=127.0.0.1

# Required in production. Use a long random secret.
JWT_SECRET=replace_with_a_long_random_secret

# Optional persistent storage locations.
# APP_ROOT=/home/ecs-user/Re-Museum
# DB_PATH=./data/remuse.db
# UPLOADS_DIR=./uploads

# Optional app origin used in verification and reset emails.
# In production this should be your public site URL, for example:
# APP_BASE_URL=https://remuse.top

# Optional operational controls.
# Admin access is controlled by users.role in the database.
# Promote an existing user with:
# node --import tsx scripts/set-user-role.ts --email founder@example.com --role admin
# DAILY_GEMINI_CALL_LIMIT=40
# DAILY_MEMORY_QUERY_LIMIT=24
# DAILY_GEMINI_IMAGE_LIMIT=40
# DAILY_STEPFUN_TEXT_LIMIT=24
# DAILY_STEPFUN_VISION_LIMIT=40
# MANAGED_UPLOAD_DELETE_GRACE_MS=60000
# DISABLE_LIVE_AI=false
# BACKUP_DIR=./backups
# ERROR_ALERT_WEBHOOK_URL=https://example.com/hooks/remuse-errors
# ERROR_ALERT_INCLUDE_WARN=false
# ERROR_ALERT_COOLDOWN_MS=60000
# ALERT_ENVIRONMENT=production
# BACKUP_RETENTION_DAYS=14
# BACKUP_ALERT_EMAILS=founder@example.com,ops@example.com
# SMOKE_ADMIN_EMAIL=founder@example.com
# ALERT_WEBHOOK_URL=https://example.com/hooks/remuse-backup
# SUPPORT_CONTACT_LABEL=微信
# SUPPORT_CONTACT_VALUE=MTtin999
# ENABLE_REMBG=false
# REMBG_COMMAND=rembg
# REMBG_MODEL=u2netp
# REMBG_MODEL_HOME=/home/ecs-user/.u2net
# REMBG_TIMEOUT_MS=20000
# REMUSE_USE_AI_EMOJI_CAPTIONS=false
# ADMIN_EMAIL_ALLOWLIST=1810365936@qq.com

# Email delivery.
# Default behavior:
# - If RESEND_API_KEY is configured, email uses Resend
# - Otherwise email falls back to log mode for local/dev testing
EMAIL_DELIVERY_MODE=log
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# MAIL_FROM_EMAIL=no-reply@remuse.top
# MAIL_FROM_NAME=Re-Museum

# Upload hardening.
MAX_UPLOAD_BYTES=6291456
MAX_IMAGE_DIMENSION=4096
MAX_INPUT_PIXELS=16777216
