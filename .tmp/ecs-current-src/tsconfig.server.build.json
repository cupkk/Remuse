{
  "extends": "./tsconfig.server.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./build/server",
    "resolveJsonModule": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "server.ts",
    "services/auth.ts",
    "services/database.ts",
    "services/storage.ts",
    "middleware/authMiddleware.ts",
    "routes/auth.ts",
    "routes/items.ts",
    "routes/stickers.ts",
    "routes/halls.ts"
  ]
}
